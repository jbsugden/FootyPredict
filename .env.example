# Football Data API key from https://www.football-data.org/
FOOTBALL_DATA_API_KEY=your_api_key_here

# SQLite (default) or PostgreSQL async URL
# Examples:
#   sqlite+aiosqlite:///./footypredict.db
#   postgresql+asyncpg://user:password@localhost/footypredict
DATABASE_URL=sqlite+aiosqlite:///./footypredict.db

# Secret key for protecting admin endpoints
ADMIN_API_KEY=change_me_to_a_strong_random_secret

# Set to true to enable debug mode (verbose logging, auto-reload)
DEBUG=false
